{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "image": {
      "type": "object",
      "required": [
        "repository",
        "pullPolicy"
      ],
      "properties": {
        "repository": {
          "type": "string"
        },
        "pullPolicy": {
          "type": "string",
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ]
        },
        "tag": {
          "type": "string"
        }
      }
    },
    "imagePullSecrets": {
      "type": "array"
    },
    "nameOverride": {
      "type": "string"
    },
    "fullnameOverride": {
      "type": "string"
    },
    "podAnnotations": {
      "type": "object"
    },
    "podSecurityContext": {
      "type": "object"
    },
    "securityContext": {
      "type": "object"
    },
    "resources": {
      "type": "object",
      "properties": {
        "limits": {
          "type": "object",
          "properties": {
            "cpu": {
              "type": [
                "string",
                "number"
              ]
            },
            "memory": {
              "type": [
                "string",
                "number"
              ]
            }
          }
        },
        "requests": {
          "type": "object",
          "properties": {
            "cpu": {
              "type": [
                "string",
                "number"
              ]
            },
            "memory": {
              "type": [
                "string",
                "number"
              ]
            }
          }
        }
      }
    },
    "nodeSelector": {
      "type": "object"
    },
    "tolerations": {
      "type": "array"
    },
    "affinity": {
      "type": "object"
    },
    "service": {
      "type": "object",
      "required": [
        "type",
        "port"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "ClusterIP",
            "NodePort",
            "LoadBalancer"
          ]
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "ingress": {
      "type": "object",
      "required": [
        "enabled",
        "host"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "className": {
          "type": "string"
        },
        "annotations": {
          "type": "object"
        },
        "host": {
          "type": "string"
        },
        "tls": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "secretName": {
              "type": "string"
            }
          }
        }
      }
    },
    "mariadb": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "auth": {
          "type": "object",
          "properties": {
            "database": {
              "type": "string"
            },
            "username": {
              "type": "string"
            },
            "password": {
              "type": "string"
            },
            "rootPassword": {
              "type": "string"
            }
          }
        }
      }
    },
    "postgresql": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "auth": {
          "type": "object",
          "properties": {
            "database": {
              "type": "string"
            },
            "username": {
              "type": "string"
            },
            "password": {
              "type": "string"
            },
            "postgresPassword": {
              "type": "string"
            },
            "existingSecret": {
              "type": "string"
            }
          },
          "if": {
            "properties": {
              "existingSecret": {
                "const": ""
              }
            }
          },
          "then": {
            "required": [
              "password",
              "postgresPassword"
            ]
          }
        }
      }
    },
    "redis": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "auth": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "password": {
              "type": "string"
            }
          }
        }
      }
    },
    "externalDatabase": {
      "type": "object",
      "properties": {
        "driver": {
          "type": "string",
          "enum": [
            "pdo_sqlite",
            "pdo_mysql",
            "pdo_pgsql"
          ]
        },
        "host": {
          "type": "string"
        },
        "port": {
          "type": "integer"
        },
        "database": {
          "type": "string"
        },
        "username": {
          "type": "string"
        },
        "password": {
          "type": "string"
        },
        "rootPassword": {
          "type": "string"
        },
        "existingSecret": {
          "type": "string"
        },
        "existingAdminSecret": {
          "type": "string"
        }
      }
    },
    "externalRedis": {
      "type": "object",
      "properties": {
        "host": {
          "type": "string"
        },
        "port": {
          "type": "integer"
        },
        "password": {
          "type": "string"
        },
        "existingSecret": {
          "type": "string"
        }
      }
    },
    "persistence": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "storageClass": {
          "type": "string"
        },
        "accessMode": {
          "type": "string",
          "enum": [
            "ReadWriteOnce",
            "ReadOnlyMany",
            "ReadWriteMany"
          ]
        },
        "size": {
          "type": "string",
          "pattern": "^[0-9]+(Gi|Mi|Ki|G|M|K)$"
        }
      }
    },
    "wallabag": {
      "type": "object",
      "properties": {
        "domainName": {
          "type": "string"
        },
        "memoryLimit": {
          "type": "string"
        },
        "serverName": {
          "type": "string"
        },
        "secret": {
          "type": "string"
        },
        "locale": {
          "type": "string"
        },
        "fromEmail": {
          "type": "string",
          "format": "email"
        },
        "twofactorSender": {
          "type": "string",
          "format": "email"
        },
        "mailerDsn": {
          "type": "string"
        },
        "sentryDsn": {
          "type": "string"
        },
        "fos": {
          "type": "object",
          "properties": {
            "userRegistration": {
              "type": "boolean"
            },
            "userConfirmation": {
              "type": "boolean"
            }
          }
        },
        "extraConfig": {
          "type": "object"
        }
      }
    }
  }
}
