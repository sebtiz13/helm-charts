# Patterns to ignore when building packages.
# This supports shell glob matching, relative path matching, and
# negation (prefixed with !). Only one pattern per line.
.DS_Store
# Common VCS dirs
hg/
git/
bzr/
.svn/
# Common backup files
*.swp
*.bak
*.backup
*~
# Various IDEs
hg/
git/
bzr/
.svn/
# Common backup files
*.swp
*.bak
*.backup
*~
# Various IDEs
.project
.idea/
*.tmproj
.vscode/
